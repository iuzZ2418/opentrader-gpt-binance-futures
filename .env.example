# Copy to .env. These defaults are paper-only and cannot reach Binance order endpoints.
APP_ENV=development
TRADER_API_BIND=127.0.0.1
TRADER_API_PORT=8000
TRADER_EXTERNAL_API_BIND=127.0.0.1
TRADER_EXTERNAL_API_PORT=8002
TRADER_INTELLIGENCE_API_BIND=127.0.0.1
TRADER_INTELLIGENCE_API_PORT=8003
TRUSTED_PROXY_IPS=127.0.0.1

# Compose infrastructure. PostgreSQL and Redis are not published to the host.
POSTGRES_DB=trader
POSTGRES_USER=trader
POSTGRES_PASSWORD=paper-local-change-me
REDIS_URL=redis://redis:6379/0
DATABASE_URL=sqlite:///data/trader.db
AUDIT_DATABASE_URL=sqlite:///data/trader_audit.db
STRATEGY_REGISTRY_PATH=data/strategy_registry.json

# Safety gates. Venue values: internal, binance_futures_demo, binance_futures_live.
# Never commit a live configuration.
TRADING_STAGE=paper
EXECUTION_VENUE=internal
ENTRY_ORDER_WAIT_SECONDS=5
ENTRY_PRICE_PROTECTION_BPS=20
CAPITAL_ALLOCATION_FRACTION=1.0
LIVE_TRADING_ENABLED=false
ALLOW_BINANCE_PRODUCTION=false
CONTROL_API_TOKEN=

# Capital and deterministic hard-risk limits.
INITIAL_CASH=100000
ASSET_UNIVERSE=BTC,ETH,SOL
FUTURES_UNIVERSE=BTCUSDT,ETHUSDT,SOLUSDT
MIN_SIGNAL_SCORE=0.82
RISK_PER_TRADE=0.01
INITIAL_POSITION_RISK=0.0075
ADD_POSITION_RISK=0.0025
MAX_ASSET_EXPOSURE=0.50
MAX_OPEN_POSITIONS=10
MAX_GROSS_EXPOSURE=3.0
MAX_NET_EXPOSURE=1.5
MAX_CORRELATION_CLUSTER_EXPOSURE=1.0
MAX_LEVERAGE=3
DAILY_DRAWDOWN_LIMIT=0.03
TOTAL_DRAWDOWN_LIMIT=0.20
CAPITAL_EPISODE_LOSS_LIMIT=0.05
TAKER_FEE_BPS=8
BASE_SLIPPAGE_BPS=3
MAX_SPREAD_BPS=10
MARKET_DATA_MAX_AGE_SECONDS=10

# GPT approval and research. Model IDs are checked at startup; there is no silent fallback.
OPENAI_API_KEY=
OPENAI_PROJECT=
# Intelligence uses a separate least-privilege project/key and never receives Binance secrets.
OPENAI_INTELLIGENCE_API_KEY=
OPENAI_INTELLIGENCE_PROJECT=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EXTRACTION_MODEL=gpt-5.6-luna
OPENAI_DECISION_MODEL=gpt-5.6-terra
OPENAI_RESEARCH_MODEL=gpt-5.6-sol
OPENAI_REQUEST_TIMEOUT_SECONDS=20
# DeepSeek V4 test alternative (the current variable names are retained for compatibility):
# OPENAI_API_KEY=<your DeepSeek API key>
# OPENAI_PROJECT=
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_DECISION_MODEL=deepseek-v4-pro
DECISION_OPEN_CONFIDENCE=0.70
DECISION_ADD_CONFIDENCE=0.80
CANDIDATE_TTL_SECONDS=120
DECISION_CYCLE_SECONDS=900
X_CONTENT_TO_OPENAI_ALLOWED=false
WEB_SEARCH_ALLOWED_DOMAINS=developers.binance.com,github.com

# Optional external collectors. Keep allowlists narrow; never execute fetched code.
X_BEARER_TOKEN=
X_ALLOWED_ACCOUNT_IDS=
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_ALLOWED_REPOSITORIES=
INTELLIGENCE_STREAM_NAME=trader:external-evidence
INTELLIGENCE_POLL_SECONDS=300
INTELLIGENCE_EVIDENCE_TTL_SECONDS=3600
GITHUB_POLL_LIMIT=30
X_STREAM_RECONNECT_SECONDS=5

# One-shot, offline research evidence import (`docker compose --profile research run --rm ...`).
# Set an absolute host path and the SHA-256 independently verified by the operator. The mounted
# JSON is data only; the validator never imports or executes code named by a manifest.
RESEARCH_MANIFEST_PATH=./research-manifest.json
RESEARCH_MANIFEST_SHA256=

# Binance USD-M Futures only. Leave credentials blank for paper mode.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_FUTURES_DEMO_URL=https://demo-fapi.binance.com
BINANCE_FUTURES_LIVE_URL=https://fapi.binance.com
BINANCE_FUTURES_DEMO_WS_URL=wss://demo-fstream.binance.com
BINANCE_FUTURES_LIVE_WS_URL=wss://fstream.binance.com
BINANCE_RECV_WINDOW_MS=5000

# Optional legacy A-share services (`docker compose --profile company up`).
COMPANY_EVENT_DB=data/company_events.db
COMPANY_EVENT_API=http://127.0.0.1:8001
COMPANY_API_BIND=127.0.0.1
COMPANY_API_PORT=8001
COMPANY_DASHBOARD_BIND=127.0.0.1
COMPANY_DASHBOARD_PORT=8501
